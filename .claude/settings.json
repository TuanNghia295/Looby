{
  "enablePlugins": {
    "skill-creator@claude-plugin-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"D:\\workplace\\-Mini-Campaign-Manager\\.claude\\hooks\\gitnexus\\gitnexus-hook.cjs\"",
            "timeout": 15,
            "statusMessage": "Enriching with GitNexus graph context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"D:\\workplace\\-Mini-Campaign-Manager\\.claude\\hooks\\gitnexus\\gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Checking GitNexus index freshness..."
          }
        ]
      }
    ]
  }
}

