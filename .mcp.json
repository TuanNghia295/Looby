{
  "mcpServers": {
    "gitnexus": {
      "command": "gitnexus",
      "args": [
        "mcp"
      ]
    },
    "serena": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--enable-web-dashboard",
        "false"
      ]
    }
  }
}
